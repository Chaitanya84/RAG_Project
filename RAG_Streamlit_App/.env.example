# OpenAI API Key (required)
# Set this in your .bashrc or export it in your shell:
#   export OPENAI_API_KEY=sk-proj-...
# Or set it in the Render/Railway dashboard as an environment variable.
# OPENAI_API_KEY=

# OpenAI Models
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Set to "1" only for local development (disables HTTPS for OAuth)
OAUTHLIB_INSECURE_TRANSPORT=1

# Redirect URI — set to your deployed URL in production
# Local: http://localhost:8501/
# Production: https://your-app.onrender.com/
REDIRECT_URI=http://localhost:8501/

# App settings
DEBUG=true
