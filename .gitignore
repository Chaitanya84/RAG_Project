# Python venvs
venv/
.env/
.venv/

# Environment variables (secrets)
*.env
!.env.example
RAG_Streamlit_App/.env

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# VS Code
.vscode/

# Streamlit
.streamlit/
!RAG_Streamlit_App/.streamlit/

# Data & generated artifacts from RAG_Streamlit_App
RAG_Streamlit_App/data/*.pdf
RAG_Streamlit_App/data/machine-learning-books-master/
RAG_Streamlit_App/data/pdfs/
# Allow .csv and .pkl knowledge base files to be committed
!RAG_Streamlit_App/data/*.csv
!RAG_Streamlit_App/data/*.pkl

# Hugging Face / SentenceTransformers cache (if inside repo by mistake)
cache/
models/
*.pt
*.bin

# OAuth / credentials backups
RAG_Streamlit_App/client_secret_*.json:Zone.Identifier
RAG_Streamlit_App/client_secret.json

# OS files
.DS_Store
Thumbs.db
